{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "git": {
    "deploymentEnabled": true
  },
  "rewrites": [
    { "source": "/api/analyze-settlement", "destination": "/api/analyze-settlement.js" },
